# 🚨 NUNCA faça commit de .env ou credenciais reais!
# Use este arquivo como referência.
# Copie para .env local e preencha com seus valores

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/redbackend

# Supabase
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_KEY=sua-chave-supabase-aqui

# OpenRouter (para IA Agent)
# Gere em: https://openrouter.ai/settings/keys
OPENROUTER_KEY=sk-or-v1-...sua-chave-aqui

# Environment
FLASK_ENV=production
DEBUG=False
